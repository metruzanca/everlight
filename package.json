{
  "name": "everlight",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "bun run db:migrate",
    "dev": "vite dev --port 3000",
    "db:generate": "bun --env-file=.env.local drizzle-kit generate",
    "db:migrate": "bun --env-file=.env.local drizzle-kit push",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@fontsource/inter": "^5.1.1",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/router-plugin": "^1.133.21",
    "@tanstack/solid-form": "latest",
    "@tanstack/solid-query": "latest",
    "@tanstack/solid-query-devtools": "latest",
    "@tanstack/solid-router": "latest",
    "@tanstack/solid-router-devtools": "latest",
    "@tanstack/solid-router-ssr-query": "latest",
    "@tanstack/solid-start": "latest",
    "@tanstack/solid-store": "latest",
    "@tanstack/store": "latest",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "nitro": "npm:nitro-nightly@latest",
    "pg": "^8.22.0",
    "solid-js": "^1.9.12",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@solidjs/testing-library": "^0.8.10",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.133.21",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
